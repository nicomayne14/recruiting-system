# ── Copy this file to .env and fill in your values ────────────────
# NEVER commit .env to git

# Notion
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_PARENT_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   # Page where DBs will be created
NOTION_COMPANIES_DB_ID=                                  # Auto-filled by setup_notion.py
NOTION_CONTACTS_DB_ID=                                   # Auto-filled by setup_notion.py
NOTION_INTERACTIONS_DB_ID=                               # Auto-filled by setup_notion.py
NOTION_APPLICATIONS_DB_ID=                               # Auto-filled by setup_notion.py

# AI APIs
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# HBS Alumni Directory (browser automation)
HBS_EMAIL=your_hbs_email@hbs.edu
HBS_PASSWORD=your_hbs_password

# LinkedIn (browser automation)
LINKEDIN_EMAIL=your_linkedin_email@gmail.com
LINKEDIN_PASSWORD=your_linkedin_password

# Gmail API (generated on first run of parse_applications.py)
GMAIL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GMAIL_TOKEN_PATH=token.json

# Optional: Demo mode (uses sample data, no real API calls)
DEMO_MODE=false
